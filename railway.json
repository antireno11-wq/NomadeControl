{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile"
  },
  "deploy": {
    "startCommand": "node_modules/.bin/prisma migrate deploy && node server.js",
    "healthcheckPath": "/login",
    "healthcheckTimeout": 120
  }
}
