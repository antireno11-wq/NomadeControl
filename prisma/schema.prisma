generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String
  isActive     Boolean      @default(true)
  phone        String?
  profilePhotoUrl String?
  positionTitle String?
  emergencyContactName String?
  emergencyContactPhone String?
  nationalId    String?
  address       String?
  city          String?
  healthProvider String?
  shiftPattern  String?
  shiftWorkDays Int?
  shiftOffDays  Int?
  shiftStartDate DateTime?
  campId       String?
  camp         Camp?        @relation(fields: [campId], references: [id], onDelete: SetNull)
  sessions     Session[]
  reports      DailyReport[]
  dailyTaskControls DailyTaskControl[]
  stockMovements   StockMovement[]
  staffMembers     StaffMember[]
  vehicleChecklists VehicleChecklist[]
  alertDeliveries AlertDelivery[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AlertDelivery {
  id         String   @id @default(cuid())
  kind       String
  targetDate DateTime
  recipientId String?
  recipient  User?    @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  status     String   @default("SENT")
  payload    String?
  createdAt  DateTime @default(now())

  @@unique([kind, targetDate])
  @@index([targetDate, kind])
}

model Camp {
  id        String        @id @default(cuid())
  name      String
  location  String?
  latitude  Float?
  longitude Float?
  capacityPeople Int      @default(0)
  potableWaterTankCapacityM3 Float? 
  blackWaterTankCapacityM3 Float?
  greyWaterTankCapacityM3 Float?
  isActive  Boolean       @default(true)
  currentShiftSupervisorId String?
  currentShiftSupervisorName String?
  currentShiftPattern String?
  currentShiftWorkDays Int?
  currentShiftOffDays Int?
  currentShiftStartDate DateTime?
  users     User[]
  reports   DailyReport[]
  dailyTaskControls DailyTaskControl[]
  stockMovements    StockMovement[]
  inventoryItems    InventoryItem[]
  staffMembers      StaffMember[]
  vehicles          Vehicle[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Project {
  id          String    @id @default(cuid())
  name        String
  code        String?   @unique
  location    String?
  isActive    Boolean   @default(true)
  vehicles    Vehicle[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, name])
}

model DailyReport {
  id             String   @id @default(cuid())
  date           DateTime
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  peopleCount    Int
  breakfastCount Int
  lunchCount     Int
  dinnerCount    Int
  snackSimpleCount      Int
  snackReplacementCount Int
  waterBottleCount      Int     @default(0)
  lodgingCount          Int
  meterReading          Float   @default(0)
  waterLiters           Int
  fuelLiters     Int
  fuelRemainingLiters   Int     @default(0)
  generator1Hours       Float   @default(0)
  generator2Hours       Float   @default(0)
  internetStatus        String  @default("FUNCIONANDO")
  blackWaterRemoved     Boolean @default(false)
  blackWaterRemovedM3   Float   @default(0)
  potableWaterTankLevelPercent Int @default(0)
  blackWaterTankLevelPercent Int @default(0)
  potableWaterDelivered Boolean @default(false)
  potableWaterDeliveredM3 Float @default(0)
  wasteFillPercent      Int     @default(0)
  chlorineLevel         Float   @default(0)
  phLevel               Float   @default(7)
  extras         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([campId, date])
}

model DailyTaskControl {
  id                  String   @id @default(cuid())
  date                DateTime
  campId              String
  camp                Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById         String
  createdBy           User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  administrativeChecks Json
  operationalChecks    Json
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([campId, date])
}

model StockMovement {
  id          String   @id @default(cuid())
  date        DateTime
  campId      String
  camp        Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName    String
  movementType String
  quantity    Float
  unit        String   @default("unidad")
  notes       String?
  createdAt   DateTime @default(now())

  @@index([campId, date])
  @@index([inventoryItemId])
}

model InventoryItem {
  id             String   @id @default(cuid())
  campId         String?
  camp           Camp?    @relation(fields: [campId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  category       String   @default("OTROS")
  unit           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  stockMovements StockMovement[]

  @@index([campId, isActive, category])
  @@unique([campId, normalizedName, unit])
}


model StaffMember {
  id             String   @id @default(cuid())
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fullName       String
  role           String?
  shiftPattern   String   @default("14x14")
  shiftWorkDays  Int      @default(14)
  shiftOffDays   Int      @default(14)
  shiftStartDate DateTime
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shiftDays      StaffShiftDay[]

  @@index([campId, isActive])
}


model StaffShiftDay {
  id            String      @id @default(cuid())
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  date          DateTime
  status        String
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([staffMemberId, date])
  @@index([date, status])
}

model Vehicle {
  id                String            @id @default(cuid())
  plate             String            @unique
  company           String?
  internalCode      String?
  brand             String
  model             String
  year              Int?
  type              String
  status            String            @default("OPERATIVO")
  accreditationStatus String         @default("PENDIENTE")
  odometerKm        Int               @default(0)
  assignedCampId    String?
  assignedCamp      Camp?             @relation(fields: [assignedCampId], references: [id], onDelete: SetNull)
  assignedProjectId String?
  assignedProject   Project?          @relation(fields: [assignedProjectId], references: [id], onDelete: SetNull)
  ownerArea         String?
  color             String?
  vin               String?
  engineNumber      String?
  circulationPermitDue DateTime?
  soapDue           DateTime?
  technicalReviewDue DateTime?
  insuranceDue      DateTime?
  extinguisherDue   DateTime?
  gpsInstalled      Boolean           @default(false)
  gpsCertificatePresent Boolean       @default(false)
  unitPhotoSet      Boolean           @default(false)
  winterKitPhotoSet Boolean           @default(false)
  uvProtectionCertificate Boolean     @default(false)
  reviewedByName    String?
  reviewedAt        DateTime?
  notes             String?
  documents         VehicleDocument[]
  checklists        VehicleChecklist[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([assignedCampId, status])
  @@index([assignedProjectId, status])
  @@index([plate])
}

model VehicleDocument {
  id           String    @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentType String    @default("OTRO")
  name         String
  number       String?
  issuer       String?
  issuedAt     DateTime?
  expiresAt    DateTime
  alertDays    Int       @default(30)
  status       String    @default("VIGENTE")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([vehicleId, expiresAt])
}

model VehicleChecklist {
  id                  String    @id @default(cuid())
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId            String
  driver              User      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  date                DateTime
  odometerKm          Int
  fuelPercent         Int
  frontLightsOk       Boolean   @default(true)
  rearLightsOk        Boolean   @default(true)
  tiresOk             Boolean   @default(true)
  brakesOk            Boolean   @default(true)
  mirrorsOk           Boolean   @default(true)
  hornOk              Boolean   @default(true)
  fluidsOk            Boolean   @default(true)
  jackOk              Boolean   @default(true)
  spareTireOk         Boolean   @default(true)
  extinguisherOk      Boolean   @default(true)
  documentsOk         Boolean   @default(true)
  bodyworkOk          Boolean   @default(true)
  cleanlinessOk       Boolean   @default(true)
  observations        String?
  incidentReported    Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([vehicleId, date])
  @@index([driverId, date])
}
