generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String
  isActive     Boolean      @default(true)
  phone        String?
  profilePhotoUrl String?
  positionTitle String?
  emergencyContactName String?
  emergencyContactPhone String?
  nationalId    String?
  address       String?
  city          String?
  healthProvider String?
  campId       String?
  camp         Camp?        @relation(fields: [campId], references: [id], onDelete: SetNull)
  sessions     Session[]
  reports      DailyReport[]
  dailyTaskControls DailyTaskControl[]
  stockMovements   StockMovement[]
  staffMembers     StaffMember[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Camp {
  id        String        @id @default(cuid())
  name      String
  location  String?
  capacityPeople Int      @default(0)
  isActive  Boolean       @default(true)
  users     User[]
  reports   DailyReport[]
  dailyTaskControls DailyTaskControl[]
  stockMovements    StockMovement[]
  inventoryItems    InventoryItem[]
  staffMembers      StaffMember[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model DailyReport {
  id             String   @id @default(cuid())
  date           DateTime
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  peopleCount    Int
  breakfastCount Int
  lunchCount     Int
  dinnerCount    Int
  snackSimpleCount      Int
  snackReplacementCount Int
  waterBottleCount      Int     @default(0)
  lodgingCount          Int
  meterReading          Float   @default(0)
  waterLiters           Int
  fuelLiters     Int
  generator1Hours       Float   @default(0)
  generator2Hours       Float   @default(0)
  internetStatus        String  @default("FUNCIONANDO")
  wasteFillPercent      Int     @default(0)
  chlorineLevel         Float   @default(0)
  phLevel               Float   @default(7)
  extras         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([campId, date])
}

model DailyTaskControl {
  id                  String   @id @default(cuid())
  date                DateTime
  campId              String
  camp                Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById         String
  createdBy           User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  administrativeChecks Json
  operationalChecks    Json
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([campId, date])
}

model StockMovement {
  id          String   @id @default(cuid())
  date        DateTime
  campId      String
  camp        Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName    String
  movementType String
  quantity    Float
  unit        String   @default("unidad")
  notes       String?
  createdAt   DateTime @default(now())

  @@index([campId, date])
  @@index([inventoryItemId])
}

model InventoryItem {
  id             String   @id @default(cuid())
  campId         String?
  camp           Camp?    @relation(fields: [campId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  category       String   @default("OTROS")
  unit           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  stockMovements StockMovement[]

  @@index([campId, isActive, category])
  @@unique([campId, normalizedName, unit])
}


model StaffMember {
  id             String   @id @default(cuid())
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fullName       String
  role           String?
  shiftStartDate DateTime
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shiftDays      StaffShiftDay[]

  @@index([campId, isActive])
}


model StaffShiftDay {
  id            String      @id @default(cuid())
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  date          DateTime
  status        String
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([staffMemberId, date])
  @@index([date, status])
}
