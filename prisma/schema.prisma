generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  role         String
  isActive     Boolean      @default(true)
  phone        String?
  profilePhotoUrl String?
  positionTitle String?
  emergencyContactName String?
  emergencyContactPhone String?
  nationalId    String?
  address       String?
  city          String?
  healthProvider String?
  shiftPattern  String?
  shiftWorkDays Int?
  shiftOffDays  Int?
  shiftStartDate DateTime?
  campId            String?
  camp              Camp?        @relation(fields: [campId], references: [id], onDelete: SetNull)
  modulePermissions Json         @default("[]")
  sessions     Session[]
  reports      DailyReport[]
  dailyTaskControls DailyTaskControl[]
  stockMovements   StockMovement[]
  staffMembers     StaffMember[]
  vehicleChecklists VehicleChecklist[]
  alertDeliveries AlertDelivery[]
  auditLogs    AuditLog[]
  incidentesReportados Incidente[]    @relation("IncidenteReportado")
  incidentesAsignados  Incidente[]    @relation("IncidenteResponsable")
  matricesRiesgo       MatrizRiesgo[] @relation("MatrizResponsable")
  eppEntregados        EntregaEPP[]   @relation("EPPEntregador")
  cursosCreados        Curso[]        @relation("CursoCreador")
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model AlertDelivery {
  id         String   @id @default(cuid())
  kind       String
  targetDate DateTime
  recipientId String?
  recipient  User?    @relation(fields: [recipientId], references: [id], onDelete: SetNull)
  status     String   @default("SENT")
  payload    String?
  createdAt  DateTime @default(now())

  @@unique([kind, targetDate])
  @@index([targetDate, kind])
}

model AuditLog {
  id          String   @id @default(cuid())
  actorUserId String?
  actorUser   User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)
  actorName   String?
  actorEmail  String?
  action      String
  entityType  String
  entityId    String?
  summary     String
  metadata    String?
  createdAt   DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([actorUserId, createdAt])
}

model Camp {
  id        String        @id @default(cuid())
  name      String
  location  String?
  latitude  Float?
  longitude Float?
  capacityPeople Int      @default(0)
  potableWaterTankCapacityM3 Float? 
  blackWaterTankCapacityM3 Float?
  greyWaterTankCapacityM3 Float?
  isActive  Boolean       @default(true)
  closedAt  DateTime?
  currentShiftSupervisorId String?
  currentShiftSupervisorName String?
  currentShiftPattern String?
  currentShiftWorkDays Int?
  currentShiftOffDays Int?
  currentShiftStartDate DateTime?
  users     User[]
  reports   DailyReport[]
  dailyTaskControls DailyTaskControl[]
  stockMovements    StockMovement[]
  inventoryItems    InventoryItem[]
  staffMembers      StaffMember[]
  vehicles          Vehicle[]
  incidentes        Incidente[]
  matricesRiesgo    MatrizRiesgo[]
  entregasEPP       EntregaEPP[]
  documentosHSEC    DocumentoHSEC[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
}

model Project {
  id          String    @id @default(cuid())
  name        String
  code        String?   @unique
  location    String?
  isActive    Boolean   @default(true)
  vehicles    Vehicle[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([isActive, name])
}

model DailyReport {
  id             String   @id @default(cuid())
  date           DateTime
  campId         String
  camp           Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  peopleCount    Int
  breakfastCount Int
  lunchCount     Int
  dinnerCount    Int
  snackSimpleCount      Int
  snackReplacementCount Int
  waterBottleCount      Int     @default(0)
  lodgingCount          Int
  meterReading          Float   @default(0)
  waterLiters           Int
  fuelLiters     Int
  fuelRemainingLiters   Int     @default(0)
  generator1Hours       Float   @default(0)
  generator2Hours       Float   @default(0)
  internetStatus        String  @default("FUNCIONANDO")
  blackWaterRemoved     Boolean @default(false)
  blackWaterRemovedM3   Float   @default(0)
  potableWaterTankLevelPercent Int @default(0)
  blackWaterTankLevelPercent Int @default(0)
  potableWaterDelivered Boolean @default(false)
  potableWaterDeliveredM3 Float @default(0)
  wasteFillPercent      Int     @default(0)
  chlorineLevel         Float   @default(0)
  phLevel               Float   @default(7)
  extras         String?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([campId, date])
}

model DailyTaskControl {
  id                  String   @id @default(cuid())
  date                DateTime
  campId              String
  camp                Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById         String
  createdBy           User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  administrativeChecks Json
  operationalChecks    Json
  notes               String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([campId, date])
}

model StockMovement {
  id          String   @id @default(cuid())
  date        DateTime
  campId      String
  camp        Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  itemName    String
  movementType String
  quantity    Float
  unit        String   @default("unidad")
  notes       String?
  createdAt   DateTime @default(now())

  @@index([campId, date])
  @@index([inventoryItemId])
}

model InventoryItem {
  id             String   @id @default(cuid())
  campId         String?
  camp           Camp?    @relation(fields: [campId], references: [id], onDelete: Cascade)
  name           String
  normalizedName String
  category       String   @default("OTROS")
  unit           String
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  stockMovements StockMovement[]

  @@index([campId, isActive, category])
  @@unique([campId, normalizedName, unit])
}


model StaffMember {
  id             String   @id @default(cuid())
  campId         String?
  camp           Camp?    @relation(fields: [campId], references: [id], onDelete: SetNull)
  createdById    String
  createdBy      User     @relation(fields: [createdById], references: [id], onDelete: Restrict)
  fullName       String
  role           String?
  employerCompany String?
  nationalId     String?
  phone          String?
  personalEmail  String?
  contractEndDate DateTime?
  altitudeExamDueDate DateTime?
  occupationalExamDueDate DateTime?
  inductionDueDate DateTime?
  accreditationDueDate DateTime?
  driversLicenseDueDate DateTime?
  shiftPattern   String   @default("14x14")
  shiftWorkDays  Int      @default(14)
  shiftOffDays   Int      @default(14)
  shiftStartDate DateTime
  isActive       Boolean  @default(true)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  shiftDays      StaffShiftDay[]
  entregasEPP    EntregaEPP[]
  inducciones    InduccionUsuario[]
  documentos     DocumentoTrabajador[]
  cierre         CierreContrato?

  @@index([campId, isActive])
}


model StaffShiftDay {
  id            String      @id @default(cuid())
  staffMemberId String
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  date          DateTime
  status        String
  notes         String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@unique([staffMemberId, date])
  @@index([date, status])
}

model Vehicle {
  id                String            @id @default(cuid())
  plate             String            @unique
  company           String?
  internalCode      String?
  brand             String
  model             String
  year              Int?
  type              String
  status            String            @default("OPERATIVO")
  accreditationStatus String         @default("PENDIENTE")
  odometerKm        Int               @default(0)
  assignedCampId    String?
  assignedCamp      Camp?             @relation(fields: [assignedCampId], references: [id], onDelete: SetNull)
  assignedProjectId String?
  assignedProject   Project?          @relation(fields: [assignedProjectId], references: [id], onDelete: SetNull)
  ownerArea         String?
  color             String?
  vin               String?
  engineNumber      String?
  circulationPermitDue DateTime?
  soapDue           DateTime?
  technicalReviewDue DateTime?
  insuranceDue      DateTime?
  extinguisherDue   DateTime?
  gpsInstalled      Boolean           @default(false)
  gpsCertificatePresent Boolean       @default(false)
  unitPhotoSet      Boolean           @default(false)
  winterKitPhotoSet Boolean           @default(false)
  uvProtectionCertificate Boolean     @default(false)
  reviewedByName    String?
  reviewedAt        DateTime?
  notes             String?
  documents         VehicleDocument[]
  checklists        VehicleChecklist[]
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([assignedCampId, status])
  @@index([assignedProjectId, status])
  @@index([plate])
}

model VehicleDocument {
  id           String    @id @default(cuid())
  vehicleId    String
  vehicle      Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  documentType String    @default("OTRO")
  name         String
  number       String?
  issuer       String?
  issuedAt     DateTime?
  expiresAt    DateTime
  alertDays    Int       @default(30)
  status       String    @default("VIGENTE")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([vehicleId, expiresAt])
}

model VehicleChecklist {
  id                  String    @id @default(cuid())
  vehicleId           String
  vehicle             Vehicle   @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  driverId            String
  driver              User      @relation(fields: [driverId], references: [id], onDelete: Restrict)
  date                DateTime
  odometerKm          Int
  fuelPercent         Int
  frontLightsOk       Boolean   @default(true)
  rearLightsOk        Boolean   @default(true)
  tiresOk             Boolean   @default(true)
  brakesOk            Boolean   @default(true)
  mirrorsOk           Boolean   @default(true)
  hornOk              Boolean   @default(true)
  fluidsOk            Boolean   @default(true)
  jackOk              Boolean   @default(true)
  spareTireOk         Boolean   @default(true)
  extinguisherOk      Boolean   @default(true)
  documentsOk         Boolean   @default(true)
  bodyworkOk          Boolean   @default(true)
  cleanlinessOk       Boolean   @default(true)
  observations        String?
  incidentReported    Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([vehicleId, date])
  @@index([driverId, date])
}

model Documento {
  id               String   @id @default(cuid())
  titulo           String
  descripcion      String?
  categoria        String
  originalFilename String
  fileSize         Int?
  mimeType         String?
  version          String?
  subidoPor        String?
  contenido        Bytes
  createdAt        DateTime @default(now())

  @@index([categoria])
  @@index([createdAt])
}

model ProyectoConfig {
  id        String   @id @default(cuid())
  nombre    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model AreaConfig {
  id        String   @id @default(cuid())
  nombre    String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Tarea {
  id          String    @id @default(cuid())
  tipo        String    @default("urgente")
  proyecto    String?
  area        String?
  descripcion String
  responsable String?
  comentario  String?
  prioridad   String    @default("media")
  estado           String    @default("pendiente")
  fechaInicio      DateTime?
  fechaCierre      DateTime?
  fechaCompletada  DateTime?
  esPrivada        Boolean   @default(false)
  creadoPor        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  comentarios TareaComentario[]

  @@index([estado])
  @@index([responsable])
  @@index([tipo])
  @@index([fechaCierre])
}

model TareaComentario {
  id          String   @id @default(cuid())
  tareaId     String
  tarea       Tarea    @relation(fields: [tareaId], references: [id], onDelete: Cascade)
  texto       String
  autorNombre String
  createdAt   DateTime @default(now())

  @@index([tareaId])
}

model Evaluacion {
  id               String   @id @default(cuid())

  // Identificación
  evaluadoNombre   String
  evaluadoCargo    String?
  periodo          String
  proyecto         String?
  evaluadorNombre  String
  evaluadorId      String?

  // II. Competencias Transversales (1-5)
  planificacion      Int?
  iniciativa         Int?
  cooperacion        Int?
  responsabilidad    Int?
  convivenciaLaboral Int?

  // III. Seguridad y Medio Ambiente (1-5)
  comunicacionSeg    Int?
  indumentaria       Int?
  elaboracionDocs    Int?
  reportabilidad     Int?
  gestionAmbiente    Int?

  // Comentarios por competencia
  comentPlanificacion   String?
  comentIniciativa      String?
  comentCooperacion     String?
  comentResponsabilidad String?
  comentConvivencia     String?
  comentComunicacion    String?
  comentIndumentaria    String?
  comentElaboracion     String?
  comentReportabilidad  String?
  comentGestion         String?

  // Puntaje calculado
  puntajeTotal Float?

  // Retroalimentación
  oportunidadesMejora  String?
  mantenerCargo        String?
  reubicar             String?
  promocion            String?
  reconocimiento       String?
  requiereCapacitacion String?
  observacionesFinales String?

  estado    String   @default("borrador") // borrador | completada
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([evaluadorId])
  @@index([evaluadoNombre])
  @@index([estado, createdAt])
}

// ─── MÓDULO HSEC / PREVENCIÓN ────────────────────────────────────────────────

model Incidente {
  id                  String    @id @default(cuid())
  titulo              String
  descripcion         String
  fechaOcurrencia     DateTime
  lugar               String
  area                String?
  criticidad          String    // baja | media | alta | critica
  estado              String    @default("abierto") // abierto | en_investigacion | cerrado
  incumplimientoLegal Boolean   @default(false)
  reportadoPorId      String
  reportadoPor        User      @relation("IncidenteReportado", fields: [reportadoPorId], references: [id])
  responsableId       String?
  responsable         User?     @relation("IncidenteResponsable", fields: [responsableId], references: [id])
  planAccion          String?
  fechaCierre         DateTime?
  evidenciaUrls       Json      @default("[]")
  campId              String?
  camp                Camp?     @relation(fields: [campId], references: [id], onDelete: SetNull)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@index([estado, createdAt])
  @@index([criticidad])
  @@index([campId])
}

model MatrizRiesgo {
  id             String    @id @default(cuid())
  tarea          String
  area           String
  peligro        String
  probabilidad   Int       // 1-5
  impacto        Int       // 1-5
  nivelRiesgo    String    // bajo | medio | alto | critico
  medidasControl String?
  responsableId  String
  responsable    User      @relation("MatrizResponsable", fields: [responsableId], references: [id])
  evidenciaUrls  Json      @default("[]")
  fechaRevision  DateTime?
  campId         String?
  camp           Camp?     @relation(fields: [campId], references: [id], onDelete: SetNull)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([nivelRiesgo])
  @@index([campId])
}

// ─── MÓDULO EPP (dentro de Trabajadores) ─────────────────────────────────────

model TipoEPP {
  id           String       @id @default(cuid())
  nombre       String
  descripcion  String?
  vigenciaDias Int          @default(365)
  isActive     Boolean      @default(true)
  entregas     EntregaEPP[]
  createdAt    DateTime     @default(now())
}

model EntregaEPP {
  id               String    @id @default(cuid())
  staffMemberId    String?
  staffMember      StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  nombreTrabajador String
  tipoEppId        String
  tipoEpp          TipoEPP   @relation(fields: [tipoEppId], references: [id])
  cantidad         Int       @default(1)
  fechaEntrega     DateTime
  fechaVencimiento DateTime
  firmaUrl         String?
  entregadoPorId   String
  entregadoPor     User      @relation("EPPEntregador", fields: [entregadoPorId], references: [id])
  campId           String?
  camp             Camp?     @relation(fields: [campId], references: [id], onDelete: SetNull)
  observaciones    String?
  createdAt        DateTime  @default(now())

  @@index([campId, fechaVencimiento])
  @@index([staffMemberId])
}

// ─── MÓDULO INDUCCIONES (dentro de Trabajadores) ─────────────────────────────

model Curso {
  id                String             @id @default(cuid())
  titulo            String
  descripcion       String?
  contenido         String
  tiempoEstimadoMin Int                @default(30)
  activo            Boolean            @default(true)
  createdById       String
  createdBy         User               @relation("CursoCreador", fields: [createdById], references: [id])
  createdAt         DateTime           @default(now())
  preguntas         PreguntaQuiz[]
  inducciones       InduccionUsuario[]

  @@index([activo])
}

model PreguntaQuiz {
  id                String @id @default(cuid())
  cursoId           String
  curso             Curso  @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  pregunta          String
  opciones          Json
  respuestaCorrecta Int
  orden             Int    @default(0)

  @@index([cursoId, orden])
}

model InduccionUsuario {
  id                String       @id @default(cuid())
  staffMemberId     String?
  staffMember       StaffMember? @relation(fields: [staffMemberId], references: [id], onDelete: SetNull)
  nombreTrabajador  String
  cursoId           String
  curso             Curso        @relation(fields: [cursoId], references: [id], onDelete: Cascade)
  estado            String       @default("pendiente") // pendiente | en_progreso | completado | reprobado
  puntaje           Int?
  intentos          Int          @default(0)
  firmaUrl          String?
  certificadoUrl    String?
  reglamentoFirmado Boolean      @default(false)
  fechaInicio       DateTime?
  fechaCompletado   DateTime?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@index([cursoId, estado])
  @@index([staffMemberId])
}

// ─── CIERRE / TÉRMINO DE CONTRATO ────────────────────────────────────────────

/// Registro de baja del trabajador: tipo de término + evaluación de salida interna
model CierreContrato {
  id            String      @id @default(cuid())
  staffMemberId String      @unique
  staffMember   StaffMember @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)

  /// finiquito | no_renovacion | renuncia | mutuo_acuerdo | otro
  tipo              String
  fechaCierre       DateTime
  motivoCierre      String?

  // ── Evaluación de salida ──────────────────────────────────────────────────
  /// excelente | bueno | regular | malo
  desempenoGeneral      String
  /// buena | regular | mala
  puntualidad           String
  /// bueno | regular | malo
  trabajoEnEquipo       String
  /// buena | regular | mala
  calidadTrabajo        String
  /// buena | regular | mala
  actitudSeguridad      String
  /// true = sí lo llamaríamos de vuelta
  recontratarRecomendado Boolean
  /// inmediata | normal | baja | no_aplica
  prioridadRecontratacion String   @default("normal")
  observaciones          String?
  evaluadoPorNombre      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([recontratarRecomendado])
  @@index([fechaCierre])
}

// ─── DOCUMENTOS CON VENCIMIENTO (sistema transversal) ────────────────────────

/// Documentos individuales de cada trabajador (contratos, licencias, exámenes, etc.)
model DocumentoTrabajador {
  id               String       @id @default(cuid())
  staffMemberId    String
  staffMember      StaffMember  @relation(fields: [staffMemberId], references: [id], onDelete: Cascade)
  /// licencia_conducir | carnet_identidad | contrato | anexo_contrato | examen_preocupacional
  /// examen_periodico | odi_firmada | induccion | capacitacion | credencial | altura_fisica
  /// altura_trabajos | espacios_confinados | antecedentes | liquidacion | finiquito | otro
  tipo             String
  nombre           String
  contenido        Bytes?
  originalFilename String?
  fileSize         Int?
  mimeType         String?
  fechaEmision     DateTime?
  fechaVencimiento DateTime?
  notas            String?
  creadoPorNombre  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([staffMemberId, fechaVencimiento])
  @@index([tipo])
}

/// Documentos del campamento (autorizaciones, planes, resoluciones, etc.)
model DocumentoHSEC {
  id               String    @id @default(cuid())
  campId           String
  camp             Camp      @relation(fields: [campId], references: [id], onDelete: Cascade)
  /// plan_emergencia | prevencion_riesgos | reglamento_hsec | autorizacion_sanitaria
  /// permiso_edificacion | resolucion_salud | cert_instalaciones | permiso_municipal
  /// contrato_servicio | documento_legal | otro
  tipo             String
  nombre           String
  contenido        Bytes?
  originalFilename String?
  fileSize         Int?
  mimeType         String?
  fechaEmision     DateTime?
  fechaVencimiento DateTime?
  responsable      String?
  notas            String?
  creadoPorNombre  String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([campId, fechaVencimiento])
  @@index([tipo])
}
